# ===== 디바이스 =====
DEVICE=auto              # auto | cuda | cpu

# ===== VLM (Qwen3-VL) =====
# 2B-Instruct: 3070 8GB에 안전. 4B 쓰려면 VLM_QUANTIZE=4bit 권장.
VLM_MODEL_ID=Qwen/Qwen3-VL-2B-Instruct
VLM_MAX_TOKENS=64
VLM_ENABLED=true
VLM_QUANTIZE=none        # none | 4bit | 8bit (bitsandbytes 필요)

# ===== LLM (파인튜닝 Qwen3) =====
LLM_BACKEND=llamacpp     # llamacpp | transformers
LLM_URL=http://127.0.0.1:8080
LLM_MODEL=qwen3-igris-1.7b
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.7
# transformers 폴백 시 머지 모델 경로
# LLM_LOCAL_PATH=../../vlm_server/finetune/igris-tuned/merged-model

# ===== RAG =====
EMBED_MODEL=BAAI/bge-m3
RAG_TOP_K=3

# ===== 서버 =====
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
